{
  "expo": {
    "name": "Vygga",
    "slug": "vygga",
    "privacy": "public",
    "platforms": [
      "android",
      "web"
    ],
    "version": "0.1.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vygga.app"
    },
    "plugins": [
      "./plugins/withYggstack",
      "./plugins/withNotificationSound",
      "expo-secure-store"
    ],
    "android": {
      "package": "com.vygga.app"
    }
  }
}

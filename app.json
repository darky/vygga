{
  "expo": {
    "name": "hello-world",
    "slug": "reagent-expo",
    "privacy": "public",
    "platforms": [
      "android",
      "web"
    ],
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.reagentexpo"
    },
    "plugins": [
      "./plugins/withYggstack",
      "expo-secure-store",
      "expo-notifications"
    ],
    "android": {
      "package": "com.anonymous.reagentexpo"
    }
  }
}
